                            alt="Shilparamam Restaurant" class="restaurant-image">
                    </div>
                    <h3><i class="fas fa-leaf"></i> Shilparamam Restaurant</h3>
                    <p><i class="fas fa-map-marker-alt"></i> Shilparamam Cultural Village (4 km from zoo)</p>
                    <p class="timings"><i class="far fa-clock"></i> 10:00 AM - 10:00 PM (Daily)</p>
                    <div class="must-try">
                        <span>Must Try:</span> South Indian Thali, Paneer Tikka
                    </div>
                </div>

                <div class="restaurant">
                    <div class="image-container">
                        <img src="https://b.zmtcdn.com/data/pictures/3/183783/9d1e5e0e1d8d7c0c0b5f4e4d5c5e5e5e.jpg"
                            alt="The Fisherman’s Wharf" class="restaurant-image">
                    </div>
                    <h3><i class="fas fa-fish"></i> The Fisherman’s Wharf</h3>
                    <p><i class="fas fa-map-marker-alt"></i> Gandipet (5 km from zoo)</p>
                    <p class="timings"><i class="far fa-clock"></i> 12:00 PM - 11:00 PM (Daily)</p>
                    <div class="must-try">
                        <span>Must Try:</span> Prawn Curry, Fish Fry
                    </div>
                </div>

                <div class="restaurant">
                    <div class="image-container">
                        <img src="https://b.zmtcdn.com/data/pictures/4/183784/9d1e5e0e1d8d7c0c0b5f4e4d5c5e5e5e.jpg"
                            alt="The Chocolate Room" class="restaurant-image">
                    </div>
                    <h3><i class="fas fa-coffee"></i> The Chocolate Room</h3>
                    <p><i class="fas fa-map-marker-alt"></i> Ameerpet (4 km from zoo)</p>
