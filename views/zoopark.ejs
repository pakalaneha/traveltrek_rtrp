            </section>

            <section class="famous-places" id="attractions">
                <h2 class="section-title"><i class="fas fa-map-marked-alt"></i> Nearby Attractions</h2>

                <div class="place">
                    <div class="image-container">
                        <img src="https://www.hyderabadtourism.travel/images/places-to-visit/headers/mir-alam-tank-hyderabad-tourism-entry-fee-timings-holidays-reviews-header.jpg"
