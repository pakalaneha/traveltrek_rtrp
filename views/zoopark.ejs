                            alt="Bawarchi Restaurant" class="restaurant-image">
                    </div>
                    <h3><i class="fas fa-pepper-hot"></i> Bawarchi Restaurant</h3>
                    <p><i class="fas fa-map-marker-alt"></i> RTC X Roads (3.5 km from zoo)</p>
                    <p class="timings"><i class="far fa-clock"></i> 11:00 AM - 11:00 PM (Daily)</p>
                    <div class="must-try">
                        <span>Must Try:</span> Hyderabadi Biryani, Chicken 65
                    </div>
                </div>

                <div class="restaurant">
                    <div class="image-container">
                        <img src="https://b.zmtcdn.com/data/pictures/1/183781/9d1e5e0e1d8d7c0c0b5f4e4d5c5e5e5e.jpg"
                            alt="Paradise Restaurant" class="restaurant-image">
                    </div>
                    <h3><i class="fas fa-utensils"></i> Paradise Restaurant</h3>
                    <p><i class="fas fa-map-marker-alt"></i> Secunderabad (4.5 km from zoo)</p>
                    <p class="timings"><i class="far fa-clock"></i> 11:00 AM - 11:00 PM (Daily)</p>
                    <div class="must-try">
                        <span>Must Try:</span> Hyderabadi Biryani, Mutton Haleem
                    </div>
                </div>

                <div class="restaurant">
                    <div class="image-container">
