<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TravelTrek - Nehru Zoological Park</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />

    <link rel="stylesheet" href="/style.css" />
    <link rel="stylesheet" href="/responsive.css" />
    <link rel="apple-touch-icon" sizes="180x180" href="img/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="img/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="img/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <style>
        :root {
            --hyderabad-blue: #1a5276;
            --charminar-gold: #f1c40f;
            --hyderabad-pink: #e84393;
            --text-dark: #2c3e50;
            --text-light: #ecf0f1;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        body {
            color: var(--text-dark);
            line-height: 1.7;
            background-attachment: fixed;
            background-size: cover;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
        }

        /* Navigation Sidebar */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            background: rgba(0, 0, 0, 0.2);
            backdrop-filter: saturate(180%) blur(10px);
            display: flex;
            width: 100%;
            justify-content: space-between;
            align-items: center;
            padding: 12px 5px;
            z-index: 10;
            color: whitesmoke;
        }

        .logo {
            font-family: var(--ff-rubik-dirt);
            font-size: 1.5rem;
            text-transform: uppercase;
            letter-spacing: 0.4rem;
            padding: 0 1.2rem;
            font-weight: 300;
            color: rgb(254, 252, 252);
        }

        .nav-links {
            display: flex;
            align-items: center;
        }

        .nav-links li {
            font-family: var(--ff-montserrat);
            margin: 0px 15px;
        }

        .nav-links li a {
            color: white;
            cursor: pointer;
        }

        .cir_border {
            padding: 6px 20px;
            font-weight: bold;
            border: 2px hidden whitesmoke;
            border-radius: 20px;
            margin: 0px -10px;
        }

        header {
            width: 100vw;
            height: 100vh;
            background-image: url("../img/bg.png");
            background-position: bottom;
            background-attachment: fixed;
            background-size: cover;
            display: flex;
            align-items: end;
            justify-content: center;
        }

        .header-content {
            font-family: var(--ff-lora);
            letter-spacing: 0.5rem;
            color: whitesmoke;
            text-align: center;
            z-index: 1;
            padding: 4rem;
            margin-bottom: 150px;
        }

        .header-content a {
            letter-spacing: 0.1rem;
        }

        .header-content h2 {
            font-size: 4vmin;
        }

        .line {
            width: 150px;
            height: 4px;
            background: #fc036b;
            margin: 10px auto;
            border-radius: 5px;
        }

        .header-content h1 {
            font-size: 7vmin;
            margin-top: 50px;
            margin-bottom: 30px;
        }

        .ctn {
            font-family: var(--ff-montserrat);
            font-size: var(--fs-links-btns);
            font-weight: 700;
            padding: 13px 50px;
            background: #fc036b;
            border-radius: 30px;
            color: whitesmoke;
        }

        .menu-btn {
            position: absolute;
            top: 30px;
            right: 30px;
            width: 40px;
            cursor: pointer;
            display: none;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            animation: fadeIn 0.8s ease-out;
            position: relative;
        }

        /* Header Styles */
        header {
            margin-top: 5%;
            width: 98%;
            text-align: center;
            margin-bottom: 40px;
            padding: 30px 0;
            background: linear-gradient(135deg, var(--hyderabad-blue), var(--text-dark));
            height: fit-content;
            color: white;
            border-radius: 12px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            position: relative;
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        header:hover {
            transform: translateY(-5px);
        }

        header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: var(--charminar-gold);
        }
        .header-content {
            font-family: var(--ff-lora);
            letter-spacing: 0.5rem;
            color: whitesmoke;
            text-align: center;
            z-index: 1;
            padding: 4rem;
            margin-bottom: 150px;
        }

        .header-title {

            justify-content: center;
            align-items: center;
            width: 100%;
        }

        .header-subcontent {
            justify-content: center;
            align-items: center;
            width: 100%;
        }

        h1 {
            font-size: 2.8rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }

        .hyderabad-badge {
            display: inline-block;
            background: var(--hyderabad-pink);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            margin-top: 10px;
            color: white;
        }

        /* Main Image */
        .main-image-container {
            position: relative;
            margin-bottom: 40px;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);
            height: 500px;
            border: 5px solid white;
            transition: transform 0.3s ease;
        }

        .main-image-container:hover {
            transform: translateY(-5px) rotate(1deg);
        }

        .main-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .main-image-container:hover .main-image {
            transform: scale(1.05);
        }

        .image-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 30px;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
            color: white;
        }

        /* Description Section */
        .description {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            border-left: 5px solid var(--hyderabad-blue);
            position: relative;
            transition: transform 0.3s ease;
        }

        .description:hover {
            transform: translateY(-3px);
        }

        .description h2 {
            color: var(--hyderabad-blue);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .description h2 i {
            margin-right: 10px;
            color: var(--hyderabad-pink);
        }

        .historical-fact {
            background-color: #f8f9fa;
            padding: 15px;
            border-left: 4px solid var(--charminar-gold);
            margin: 20px 0;
            font-style: italic;
        }

        /* Nearby Sections */
        .nearby-section {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            margin-bottom: 40px;
        }

        .restaurants,
        .famous-places {
            flex: 1;
            min-width: 300px;
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .restaurants {
            border-top: 5px solid var(--hyderabad-pink);
        }

        .famous-places {
            border-top: 5px solid var(--charminar-gold);
        }

        .restaurants:hover {
            transform: translateY(-5px) translateX(5px);
        }

        .famous-places:hover {
            transform: translateY(-5px) translateX(-5px);
        }

        .section-title {
            color: var(--hyderabad-blue);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .section-title i {
            margin-right: 10px;
            color: var(--hyderabad-pink);
        }

        /* Restaurant Cards */
        .restaurant {
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px dashed #eee;
            transition: all 0.3s ease;
        }

        .restaurant:hover {
            transform: translateY(-3px);
            padding-left: 10px;
            border-left: 3px solid var(--hyderabad-pink);
        }

        .restaurant:last-child,
        .place:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }

        .restaurant h3,
        .place h3 {
            color: var(--text-dark);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
        }

        .restaurant h3 i,
        .place h3 i {
            margin-right: 8px;
            color: var(--hyderabad-pink);
        }

        .image-container {
            width: 100%;
            height: 200px;
            overflow: hidden;
            border-radius: 8px;
            margin-bottom: 15px;
            position: relative;
        }

        .accommodations {
            border-top: 5px solid var(--hyderabad-blue);
        }

        .accommodations:hover {
            transform: translateY(-5px);
        }

        .restaurants,
        .famous-places,
        .accommodations {
            flex: 1;
            min-width: 300px;
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }

        .restaurant-image,
        .place-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .restaurant:hover .restaurant-image,
        .place:hover .place-image {
            transform: scale(1.05);
        }

        .hyderabadi-badge {
            background-color: var(--hyderabad-pink);
            color: white;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            margin-left: 5px;
        }

        .must-try {
            background-color: #fff9e6;
            padding: 12px 15px;
            border-radius: 8px;
            margin-top: 12px;
            border-left: 3px solid var(--charminar-gold);
        }

        .timings {
            font-style: italic;
            color: #7f8c8d;
            margin: 8px 0;
            display: flex;
            align-items: center;
        }

        .timings i {
            margin-right: 8px;
            color: var(--charminar-gold);
        }

        /* Famous Places */
        .place {
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px dashed #eee;
            transition: all 0.3s ease;
        }

        .place:hover {
            transform: translateY(-3px);
            padding-left: 10px;
            border-left: 3px solid var(--charminar-gold);
        }

        .distance {
            display: flex;
            align-items: center;
            color: #7f8c8d;
            margin: 8px 0;
        }

        .distance i {
            margin-right: 8px;
            color: var(--hyderabad-blue);
        }

        /* Google Maps Section */
        .maps-section {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 40px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            border-bottom: 5px solid var(--hyderabad-pink);
            /* transition olhou: transform 0.3s ease; */
        }

        .maps-section:hover {
            transform: translateY(-3px);
        }

        .maps-container {
            height: 450px;
            width: 100%;
            margin-top: 20px;
            border-radius: 8px;
            overflow: hidden;
            background-color: #eee;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #ddd;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 20px;
            color: var(--text-dark);
            font-size: 0.9rem;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .sidebar {
                display: none;
            }

            .nearby-section {
                flex-direction: column;
            }

            .main-image-container {
                height: 350px;
            }

            h1 {
                font-size: 2.2rem;
            }

            .image-container {
                height: 180px;
            }
        }
    </style>
</head>

